{
	"compilerOptions": {
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES6",
		"allowSyntheticDefaultImports": true,
		"importHelpers": true,
		"isolatedModules": true,
		"lib": ["ES6", "DOM"],
		"moduleResolution": "node",
		"strict": true,
		"skipLibCheck": true
	},
	"include": ["**/*.ts"],
	"exclude": ["node_modules"]
}
